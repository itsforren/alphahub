# Integration Test Environment Variables
# Copy to .env.test and fill in values.
# NEVER use live Stripe keys.

# Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key (has full DB access, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe TEST mode secret key (must start with sk_test_ or rk_test_)
# NEVER use sk_live_ or rk_live_ keys -- the test suite will refuse to run
STRIPE_TEST_SECRET_KEY=

# Billing edge function secret (must match the value in Supabase edge function secrets)
BILLING_EDGE_SECRET=
